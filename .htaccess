# Safety net if document root is the project root (prefer public/ as docroot)
<IfModule mod_rewrite.c>
RewriteEngine On

# Never serve sensitive paths from project root
RewriteRule ^(\.env|app/|database/|routes/|lang/|storage/|docker/|vendor/) - [F,L]
RewriteRule (^|/)\. - [F,L]
RewriteRule \.(env|sql|log|lock)$ - [F,L]

# If already under public/, stop
RewriteRule ^public/ - [L]

# Route everything through public/
RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

# Fallback deny for direct file access when rewrite is unavailable
<FilesMatch "^\.env">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</FilesMatch>
